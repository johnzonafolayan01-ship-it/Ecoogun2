# EcoOgun Environment Configuration
# Copy this file to .env and fill in real values

# ── Supabase ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://placeholder.supabase.co
VITE_SUPABASE_ANON_KEY=placeholder-anon-key

# ── Twilio (used only in the Edge Function, NOT in the browser) ───────────
TWILIO_ACCOUNT_SID=ACplaceholder
TWILIO_AUTH_TOKEN=placeholder-auth-token

# Unified EcoVoice Twilio WhatsApp number (sandbox: +14155238886)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Agency target numbers (WhatsApp Business numbers) ────────────────────
# Replace these with real Ogun State agency WhatsApp numbers
OGWAMA_NUMBER=whatsapp:+2348012345678
OGRMA_NUMBER=whatsapp:+2348023456789
MOE_NUMBER=whatsapp:+2348034567890
